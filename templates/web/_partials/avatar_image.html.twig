{% macro avatar(path, alt, class, eager, sizes) %}
    {% if path %}
        {% set thumb = path|replace({'.webp': '.thumb.webp'}) %}
        {% set hasVariants = thumb != path %}
        <img
            class="{{ class }}"
            src="{{ asset('uploads/avatars/' ~ path) }}"
            alt="{{ alt }}"
            {% if hasVariants %}
                srcset="{{ asset('uploads/avatars/' ~ thumb) }} 160w, {{ asset('uploads/avatars/' ~ path) }} 1200w"
                sizes="{{ sizes|default('3rem') }}"
            {% endif %}
            {% if eager|default(false) %}
                loading="eager" fetchpriority="high"
            {% else %}
                loading="lazy" decoding="async"
            {% endif %}
        >
    {% endif %}
{% endmacro %}
