{# Line icons traced from original sheets. #}
{% set id = roomId|default('dev') %}
<span class="house-rooms__icon house-rooms__icon--{{ id }}" aria-hidden="true">
    <svg class="house-rooms__svg" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
        {% if id == 'dev' %}
            <path d="M24 6.5 38.2 14.7v16.6L24 39.5 9.8 31.3V14.7L24 6.5Z" stroke="currentColor" stroke-width="1.35" stroke-linejoin="round"/>
            <circle cx="24" cy="6.5" r="2.05" class="house-rooms__accent"/>
            <circle cx="38.2" cy="14.7" r="1.55" stroke="currentColor" stroke-width="1.25"/>
            <circle cx="38.2" cy="31.3" r="1.55" stroke="currentColor" stroke-width="1.25"/>
            <circle cx="24" cy="39.5" r="1.55" stroke="currentColor" stroke-width="1.25"/>
            <circle cx="9.8" cy="31.3" r="1.55" stroke="currentColor" stroke-width="1.25"/>
            <circle cx="9.8" cy="14.7" r="1.55" stroke="currentColor" stroke-width="1.25"/>
            <path d="M18.2 20.2 14.8 24l3.4 3.8M29.8 20.2 33.2 24l-3.4 3.8M26.2 18.4 21.8 29.6" stroke="currentColor" stroke-width="1.45" stroke-linecap="round" stroke-linejoin="round"/>
        {% elseif id == 'cases' %}
            <rect x="15.2" y="7.8" width="23.5" height="15.8" rx="2.3" stroke="currentColor" stroke-width="1.3"/>
            <circle cx="31.8" cy="10.8" r="0.95" fill="currentColor"/>
            <circle cx="34.7" cy="10.8" r="0.95" class="house-rooms__accent"/>
            <rect x="8.8" y="16.2" width="24.8" height="20.2" rx="2.4" stroke="currentColor" stroke-width="1.35"/>
            <path d="M8.8 19.8h24.8" stroke="currentColor" stroke-width="1.1" opacity="0.55"/>
            <circle cx="27.1" cy="18.8" r="0.95" fill="currentColor"/>
            <circle cx="30.1" cy="18.8" r="0.95" class="house-rooms__accent"/>
            <rect x="11.6" y="22.4" width="7.4" height="7.4" rx="1.05" stroke="currentColor" stroke-width="1.25"/>
            <path d="M21.2 23.6h10.2M21.2 26.4h10.2M21.2 29.2h7.1" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
        {% elseif id == 'chronicle' %}
            <circle cx="24" cy="24" r="5.4" stroke="currentColor" stroke-width="1.15" stroke-dasharray="1.35 1.55"/>
            <circle cx="24" cy="24" r="10.2" stroke="currentColor" stroke-width="1.15" stroke-dasharray="1.55 1.75"/>
            <circle cx="24" cy="24" r="15.4" stroke="currentColor" stroke-width="1.15" stroke-dasharray="1.75 1.95"/>
            <circle cx="24" cy="8.6" r="1.25" fill="currentColor"/>
            <circle cx="39.4" cy="24" r="1.25" fill="currentColor"/>
            <circle cx="24" cy="39.4" r="1.25" fill="currentColor"/>
            <circle cx="8.6" cy="24" r="1.25" fill="currentColor"/>
            <circle cx="28.6" cy="26.8" r="1.25" fill="currentColor"/>
            <circle cx="24" cy="24" r="2.05" class="house-rooms__accent"/>
        {% elseif id == 'lab' %}
            <circle cx="24" cy="24" r="7.2" stroke="currentColor" stroke-width="1.2"/>
            <circle cx="24" cy="16.8" r="7.2" stroke="currentColor" stroke-width="1.2"/>
            <circle cx="30.24" cy="20.4" r="7.2" stroke="currentColor" stroke-width="1.2"/>
            <circle cx="30.24" cy="27.6" r="7.2" stroke="currentColor" stroke-width="1.2"/>
            <circle cx="24" cy="31.2" r="7.2" stroke="currentColor" stroke-width="1.2"/>
            <circle cx="17.76" cy="27.6" r="7.2" stroke="currentColor" stroke-width="1.2"/>
            <circle cx="17.76" cy="20.4" r="7.2" stroke="currentColor" stroke-width="1.2"/>
            <circle cx="24" cy="24" r="2" class="house-rooms__accent"/>
        {% elseif id == 'music' %}
            <path d="M10 22.5v3" stroke="currentColor" stroke-width="1.45" stroke-linecap="round"/>
            <path d="M14.5 20v6" stroke="currentColor" stroke-width="1.45" stroke-linecap="round"/>
            <path d="M19 16.5v15" stroke="currentColor" stroke-width="1.45" stroke-linecap="round"/>
            <path d="M24 11v26" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <path d="M29 16.5v15" stroke="currentColor" stroke-width="1.45" stroke-linecap="round"/>
            <path d="M33.5 20v6" stroke="currentColor" stroke-width="1.45" stroke-linecap="round"/>
            <path d="M38 22.5v3" stroke="currentColor" stroke-width="1.45" stroke-linecap="round"/>
            <circle cx="24" cy="24" r="2.05" class="house-rooms__accent"/>
        {% else %}
            <circle cx="18.6" cy="24" r="10.2" stroke="currentColor" stroke-width="1.35"/>
            <circle cx="29.4" cy="24" r="10.2" stroke="currentColor" stroke-width="1.35"/>
            <circle cx="24" cy="24" r="2.05" class="house-rooms__accent"/>
        {% endif %}
    </svg>
</span>
