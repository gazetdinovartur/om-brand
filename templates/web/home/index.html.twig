{% extends 'web/layout.html.twig' %}
{% import 'web/_partials/content_card.html.twig' as contentCard %}
{% import 'web/_partials/avatar_image.html.twig' as avatarImage %}

{% block body %}
    {% set hero = blocksBySlug.hero|default(null) %}
    {% set audience = blocksBySlug.audience|default(null) %}
    {% set pains = blocksBySlug.pains|default(null) %}
    {% set specialization = blocksBySlug.specialization|default(null) %}
    {% set services = blocksBySlug.services|default(null) %}
    {% set philosophy = blocksBySlug.philosophy|default(null) %}
    {% set process = blocksBySlug.process|default(null) %}
    {% set workFormats = blocksBySlug.work_formats|default(null) %}
    {% set formIntro = blocksBySlug.form_intro|default(null) %}

    <section class="hero" id="top">
        <div class="container hero__inner">
            <div class="hero__content">
                {% if hero %}
                    <h1 class="hero__title">{{ hero.title }}</h1>
                    {% if hero.subtitle %}
                        <p class="hero__subtitle">{{ hero.subtitle }}</p>
                    {% endif %}
                    {% set heroLead = hero.body|default('') %}
                    {% if heroLead %}
                        <p class="hero__lead">{{ heroLead }}</p>
                    {% endif %}
                {% endif %}
            </div>
            <div class="hero__visual">
                <div class="hero__avatar-frame">
                    {% if settings.avatarPath %}
                        {{ avatarImage.avatar(settings.avatarPath, siteName, 'hero__avatar', true) }}
                    {% else %}
                        <div class="hero__avatar hero__avatar--placeholder" aria-hidden="true">
                            <span>{{ settings.name|slice(0, 1) }}</span>
                        </div>
                    {% endif %}
                    <div class="hero__sun-ring" aria-hidden="true"></div>
                </div>
            </div>
        </div>
        <div class="hero__actions">
            <div class="container">
                <a class="btn btn-primary" href="#contact">Рассказать о задаче</a>
            </div>
        </div>
        <div class="hero__arc" aria-hidden="true"></div>
    </section>

    {% if audience %}
        <section class="section section--soft" id="about">
            <div class="container">
                <h2 class="section__title">{{ audience.title }}</h2>
                <p class="section__text section__text--brand">{{ audience.body }}</p>
            </div>
        </section>
    {% endif %}

    {% if pains %}
        <section class="section" id="pains">
            <div class="container">
                <div class="section__head">
                    <h2 class="section__title">{{ pains.title }}</h2>
                    {% if pains.subtitle %}<p class="section__subtitle">{{ pains.subtitle }}</p>{% endif %}
                </div>
                <ul class="checklist">
                    {% for item in pains.items|default([]) %}
                        <li class="checklist__item">
                            <span class="checklist__mark" aria-hidden="true"></span>
                            <span class="checklist__text">{{ item.text }}</span>
                        </li>
                    {% endfor %}
                </ul>
            </div>
        </section>
    {% endif %}

    {% if specialization %}
        <section class="section section--soft" id="approach">
            <div class="container narrow text-center">
                <h2 class="section__title">{{ specialization.title }}</h2>
                {% set specializationParts = specialization.body|split('\n\n') %}
                <p class="section__text">{{ specializationParts[0] }}</p>
                {% if specializationParts[1]|default('') %}
                    <p class="section__text section__text--brand">{{ specializationParts[1] }}</p>
                {% endif %}
            </div>
        </section>
    {% endif %}

    {% if services %}
        <section class="section" id="services">
            <div class="container">
                <h2 class="section__title text-center">{{ services.title }}</h2>
                <div class="cards cards--catalog">
                    {% for item in services.items|default([]) %}
                        {{ contentCard.catalog(item) }}
                    {% endfor %}
                </div>
            </div>
        </section>
    {% endif %}

    {% if philosophy %}
        <section class="section section--accent" id="philosophy">
            <div class="container narrow text-center">
                <h2 class="section__title section__title--light">{{ philosophy.title }}</h2>
                <p class="section__text section__text--light">{{ philosophy.body }}</p>
            </div>
        </section>
    {% endif %}

    {% if process %}
        <section class="section" id="process">
            <div class="container">
                <div class="section__head">
                    <h2 class="section__title">{{ process.title }}</h2>
                    {% if process.subtitle %}<p class="section__subtitle">{{ process.subtitle }}</p>{% endif %}
                </div>
                <ol class="steps">
                    {% for item in process.items|default([]) %}
                        <li class="steps__item">
                            <span class="steps__num">{{ loop.index }}</span>
                            <div class="steps__body">
                                <h3 class="steps__title">{{ item.title }}</h3>
                                <p class="steps__text">{{ item.text }}</p>
                            </div>
                        </li>
                    {% endfor %}
                </ol>
            </div>
        </section>
    {% endif %}

    {% if workFormats %}
        <section class="section section--soft" id="formats">
            <div class="container">
                <div class="section__head text-center">
                    <h2 class="section__title">{{ workFormats.title }}</h2>
                    {% if workFormats.subtitle %}<p class="section__subtitle">{{ workFormats.subtitle }}</p>{% endif %}
                </div>
                <div class="cards cards--catalog">
                    {% for item in workFormats.items|default([]) %}
                        {{ contentCard.catalog(item) }}
                    {% endfor %}
                </div>
            </div>
        </section>
    {% endif %}

    {% if cases is not empty %}
        <section class="section" id="cases">
            <div class="container">
                <h2 class="section__title">Кейсы</h2>
                <div class="cards">
                    {% for case in cases %}
                        <article class="card">
                            {% if case.coverImagePath %}
                                {% set cover = case.coverImagePath %}
                                {% set thumb = cover|replace({'.webp': '.thumb.webp'}) %}
                                <img
                                    class="card__cover"
                                    src="{{ asset('uploads/' ~ cover) }}"
                                    alt="{{ case.title }}"
                                    {% if thumb != cover %}
                                        srcset="{{ asset('uploads/' ~ thumb) }} 640w, {{ asset('uploads/' ~ cover) }} 1200w"
                                        sizes="(max-width: 768px) 100vw, 320px"
                                    {% endif %}
                                    loading="lazy"
                                    decoding="async"
                                >
                            {% endif %}
                            <h3 class="card__title">{{ case.title }}</h3>
                            <p class="card__text">{{ case.summary }}</p>
                        </article>
                    {% endfor %}
                </div>
            </div>
        </section>
    {% endif %}

    <section class="section section--form" id="contact">
        <div class="container narrow">
            {% if formIntro %}
                <div class="section__head">
                    <h2 class="section__title text-center">{{ formIntro.title }}</h2>
                    {% if formIntro.body %}<p class="section__text">{{ formIntro.body }}</p>{% endif %}
                    {% if formIntro.subtitle %}<p class="section__text--brand">{{ formIntro.subtitle }}</p>{% endif %}
                </div>
            {% endif %}

            <div class="form-card" data-inquiry-card>
                <div class="form-card__loader" data-inquiry-loader hidden aria-live="polite">
                    <span class="form-card__loader-spinner" aria-hidden="true"></span>
                    <span class="form-card__loader-text">Отправляем…</span>
                </div>
                {{ form_start(form, { attr: {
                    class: 'inquiry-form',
                    'data-inquiry-form': '',
                    'data-form-name': form.vars.name,
                    enctype: 'multipart/form-data',
                    novalidate: 'novalidate'
                } }) }}
                    <div class="form-grid">
                        <div class="form-field">
                            {{ form_label(form.name) }}
                            {{ form_widget(form.name, { attr: { class: 'form-control' } }) }}
                            {{ form_errors(form.name) }}
                        </div>
                        <div class="form-field">
                            {{ form_label(form.contactType) }}
                            {{ form_widget(form.contactType, { attr: { class: 'form-control' } }) }}
                            {{ form_errors(form.contactType) }}
                        </div>
                        <div class="form-field" data-contact-field>
                            {{ form_label(form.contact) }}
                            {{ form_widget(form.contact, { attr: { class: 'form-control' } }) }}
                            <p class="form-field__hint" data-contact-hint hidden></p>
                            {{ form_errors(form.contact) }}
                        </div>
                        <div class="form-field">
                            {{ form_label(form.inquiryType) }}
                            {{ form_widget(form.inquiryType, { attr: { class: 'form-control' } }) }}
                            {{ form_errors(form.inquiryType) }}
                        </div>
                        <div class="form-field form-field--full">
                            <div class="form-field__head">
                                {{ form_label(form.message) }}
                                <span class="form-field__optional">необязательно</span>
                            </div>
                            {{ form_widget(form.message, { attr: { class: 'form-control' } }) }}
                            {{ form_errors(form.message) }}
                        </div>
                        <div class="form-field form-field--full">
                            <div class="form-field__head">
                                <span class="form-field__label">Прикрепить файл</span>
                                <span class="form-field__optional">необязательно</span>
                            </div>
                            <div class="file-upload" data-file-upload>
                                <div class="file-upload__dropzone" data-file-dropzone tabindex="0" role="button" aria-label="Выбрать файл для прикрепления">
                                    <span class="file-upload__icon" aria-hidden="true"></span>
                                    <span class="file-upload__prompt">Перетащите сюда или <span class="file-upload__accent">выберите файл</span></span>
                                    <span class="file-upload__hint">Фото, PDF, TXT или Word · до 5 МБ</span>
                                </div>
                                <div class="file-upload__preview" data-file-preview hidden>
                                    <div class="file-upload__file">
                                        <span class="file-upload__file-icon" aria-hidden="true"></span>
                                        <span class="file-upload__file-meta">
                                            <span class="file-upload__file-name" data-file-name></span>
                                            <span class="file-upload__file-size" data-file-size></span>
                                        </span>
                                    </div>
                                    <button type="button" class="file-upload__remove" data-file-remove aria-label="Убрать файл">Убрать</button>
                                </div>
                                <div class="file-upload__input">
                                    {{ form_widget(form.attachment, { attr: {
                                        class: 'file-upload__native',
                                        'data-file-input': '',
                                        accept: 'image/jpeg,image/png,image/webp,image/gif,text/plain,application/pdf,.doc,.docx'
                                    } }) }}
                                </div>
                                {{ form_errors(form.attachment) }}
                            </div>
                        </div>
                    </div>
                    {{ form_widget(form.website) }}
                    <div class="form-field form-field--full form-consent">
                        <label class="form-consent__label" for="{{ form.consent.vars.id }}">
                            {{ form_widget(form.consent, { attr: { class: 'form-consent__checkbox' } }) }}
                            <span class="form-consent__text">
                                Я согласен(а) на
                                <a href="{{ path('web_privacy') }}" target="_blank" rel="noopener">обработку персональных данных</a>
                            </span>
                        </label>
                        {{ form_errors(form.consent) }}
                    </div>
                    {% if turnstileSiteKey %}
                        <div class="form-field form-field--full turnstile-wrap" data-turnstile-wrap>
                            <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
                            <div class="cf-turnstile" data-sitekey="{{ turnstileSiteKey }}" data-theme="light"></div>
                        </div>
                    {% endif %}
                    <button type="submit" class="btn btn-primary btn-block" data-inquiry-submit>Отправить</button>
                    {% include 'web/_partials/form_feedback.html.twig' %}
                {{ form_end(form) }}
            </div>
        </div>
    </section>
{% endblock %}
