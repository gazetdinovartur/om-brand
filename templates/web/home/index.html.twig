{% extends 'web/layout.html.twig' %}
{% import 'web/_partials/avatar_image.html.twig' as avatarImage %}

{% block body %}
<div class="house-screen">
    <section class="house-greeting" aria-labelledby="house-greeting-title">
        <div class="house-greeting__portrait">
            {% if settings.avatarPath %}
                {{ avatarImage.avatar(settings.avatarPath, siteName, 'house-greeting__avatar', true, '(max-width: 768px) 5.5rem, 7rem') }}
            {% else %}
                <div class="house-greeting__avatar house-greeting__avatar--placeholder" aria-hidden="true">
                    <span>{{ settings.name|slice(0, 1) }}</span>
                </div>
            {% endif %}
            <span class="house-greeting__ring" aria-hidden="true"></span>
        </div>

        <div class="house-greeting__text">
            <h1 class="house-greeting__title" id="house-greeting-title">{{ heroGreeting }}</h1>
            <p class="house-greeting__lead">{{ heroLead }}</p>
        </div>
    </section>

    <nav class="house-rooms" aria-label="Комнаты экосистемы">
        <ul class="house-rooms__list">
            {% for room in mapRooms %}
                <li class="house-rooms__item">
                    <a
                        class="house-rooms__door"
                        href="{{ room.href }}"
                        {% if room.external %}target="_blank" rel="noopener"{% endif %}
                    >
                        <span class="house-rooms__index" aria-hidden="true">{{ '%02d'|format(loop.index) }}</span>
                        {% include 'web/_partials/house_room_icon.html.twig' with { roomId: room.id } %}
                        <span class="house-rooms__copy">
                            <span class="house-rooms__label">{{ room.label }}</span>
                            <span class="house-rooms__invite">{{ room.invite }}</span>
                        </span>
                        <span class="house-rooms__enter" aria-hidden="true">войти</span>
                    </a>
                </li>
            {% endfor %}
        </ul>
    </nav>
</div>
{% endblock %}
