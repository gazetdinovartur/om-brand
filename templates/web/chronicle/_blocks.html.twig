{% for block in blocks %}
    {% set type = block.type.value %}
    {% if type == 'paragraph' %}
        <div class="chronicle-block chronicle-block--paragraph">
            {{ block.body|chronicle_markdown|raw }}
        </div>
    {% elseif type == 'heading' %}
        {% set anchor = block.anchorId %}
        <h{{ block.headingLevel }} class="chronicle-block chronicle-block--heading"{% if anchor %} id="{{ anchor }}"{% endif %}>{{ block.body }}</h{{ block.headingLevel }}>
    {% elseif type == 'quote' %}
        <blockquote class="chronicle-block chronicle-block--quote">
            <p>{{ block.body|chronicle_markdown|raw }}</p>
            {% if block.author %}<footer>— {{ block.author }}</footer>{% endif %}
        </blockquote>
    {% elseif type == 'callout' and block.calloutStyle|default('note') != 'meta' %}
        {# meta (❤ likes) kept in DB, hidden on the site for now #}
        <aside class="chronicle-block chronicle-block--callout chronicle-block--callout-{{ block.calloutStyle|default('note') }}">
            {{ block.body|chronicle_markdown|raw }}
        </aside>
    {% elseif type == 'divider' %}
        <hr class="chronicle-block chronicle-block--divider">
    {% elseif type == 'image' %}
        {% set full = chronicle_image(block.imagePath, ['chronicle/inline', 'chronicle/covers', 'chronicle/gallery']) %}
        {% if full %}
            <figure class="chronicle-block chronicle-block--image" data-lightbox-gallery>
                <button
                    type="button"
                    class="chronicle-block__image-trigger"
                    data-lightbox-open
                    data-lightbox-src="{{ asset(full) }}"
                    data-lightbox-alt="{{ block.alt|default(entry.title) }}"
                    data-lightbox-caption="{{ block.caption|default('') }}"
                >
                    <img
                        class="chronicle-block__image"
                        src="{{ asset(full) }}"
                        alt="{{ block.alt|default(entry.title) }}"
                        loading="lazy"
                        decoding="async"
                    >
                </button>
                {% if block.caption %}<figcaption>{{ block.caption }}</figcaption>{% endif %}
            </figure>
        {% endif %}
    {% elseif type == 'gallery' and block.images is not empty %}
        <section class="chronicle-block case-gallery" aria-label="Галерея" data-lightbox-gallery>
            <div class="case-gallery__grid">
                {% for image in block.images %}
                    {% set full = chronicle_image(image.imagePath, ['chronicle/gallery', 'chronicle/inline', 'chronicle/covers']) %}
                    {% if full %}
                        <figure class="case-gallery__item">
                            <button
                                type="button"
                                class="case-gallery__trigger"
                                data-lightbox-open
                                data-lightbox-src="{{ asset(full) }}"
                                data-lightbox-alt="{{ image.alt|default(entry.title) }}"
                                data-lightbox-caption="{{ image.caption|default('') }}"
                                data-lightbox-index="{{ loop.index0 }}"
                            >
                                <img
                                    class="case-gallery__img"
                                    src="{{ asset(full) }}"
                                    alt="{{ image.alt|default(entry.title) }}"
                                    loading="lazy"
                                    decoding="async"
                                >
                            </button>
                            {% if image.caption %}<figcaption>{{ image.caption }}</figcaption>{% endif %}
                        </figure>
                    {% endif %}
                {% endfor %}
            </div>
        </section>
    {% elseif type == 'audio' %}
        <section class="chronicle-block chronicle-block--audio chronicle-audio-premium">
            <div class="chronicle-audio-premium__shell">
                <div class="chronicle-audio-premium__meta">
                    <span class="chronicle-audio-premium__badge" aria-hidden="true">♫</span>
                    <div class="chronicle-audio-premium__titles">
                        <p class="chronicle-audio-premium__label">Аудио</p>
                        {% if block.caption %}
                            <p class="chronicle-audio-premium__title">{{ block.caption }}</p>
                        {% endif %}
                    </div>
                </div>
                <div class="chronicle-audio-premium__player">
                    {% if block.omTrackSlug %}
                        <om-player
                            mode="embed"
                            track="{{ block.omTrackSlug }}"
                            api-base="{{ chronicle_om_player_api() }}"
                            theme="light"
                            aria-label="{{ block.caption|default('Аудио') }}"
                        ></om-player>
                    {% elseif block.videoUrl %}
                        {% set audioSrc = block.videoUrl matches '/^https?:\\/\\//' ? block.videoUrl : asset('uploads/' ~ block.videoUrl) %}
                        <audio class="chronicle-audio-premium__native" controls preload="metadata" src="{{ audioSrc }}">
                            Ваш браузер не поддерживает воспроизведение аудио.
                        </audio>
                    {% endif %}
                </div>
            </div>
        </section>
    {% elseif type == 'video' and block.videoUrl %}
        {% set videoEmbed = chronicle_video_embed(block) %}
        {% if videoEmbed %}
            <section class="chronicle-block chronicle-block--video">
                {% if videoEmbed.provider == 'link' %}
                    <a class="btn btn-secondary" href="{{ videoEmbed.embedUrl }}" rel="noopener" target="_blank">{{ videoEmbed.title }}</a>
                {% else %}
                    <div class="case-presentation__frame">
                        <iframe src="{{ videoEmbed.embedUrl }}" title="{{ videoEmbed.title }}" loading="lazy" allowfullscreen></iframe>
                    </div>
                {% endif %}
            </section>
        {% endif %}
    {% endif %}
{% endfor %}
