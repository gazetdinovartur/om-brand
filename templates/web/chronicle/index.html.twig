{% extends 'web/layout.html.twig' %}

{% block body %}
{% set filterCount = (activeSeries ? 1 : 0) + (activeEra ? 1 : 0) + (activeTag ? 1 : 0) + (activeYear ? 1 : 0) + (activeFeatured ? 1 : 0) %}
<section class="section chronicle-hub">
    <div class="container">
        <header class="chronicle-hub__head">
            <p class="chronicle-hub__eyebrow">Хроника</p>
            <h1 class="chronicle-hub__title">Тексты и фото по эпохам</h1>
            {% if filterCount > 0 %}
                <p class="chronicle-hub__filter-note">
                    {% if activeSeries %}Канал: <strong>{{ activeSeries.title }}</strong>{% endif %}
                    {% if activeEra %}{% if activeSeries %} · {% endif %}Эпоха: <strong>{{ activeEra.title }}</strong>{% endif %}
                    {% if activeTag %}{% if activeSeries or activeEra %} · {% endif %}Тег: <strong>#{{ activeTag.name }}</strong>{% endif %}
                    {% if activeYear %}{% if activeSeries or activeEra or activeTag %} · {% endif %}Год: <strong>{{ activeYear }}</strong>{% endif %}
                    {% if activeFeatured %}{% if activeSeries or activeEra or activeTag or activeYear %} · {% endif %}<strong>Избранное</strong>{% endif %}
                    <span class="chronicle-hub__count"> · {{ total }}</span>
                </p>
            {% else %}
                <p class="chronicle-hub__filter-note">{{ total }} записей</p>
            {% endif %}
        </header>

        <form class="chronicle-hub__filters" method="get" action="{{ path('web_chronicle') }}" data-chronicle-filters>
            {% if filterQuery.series is defined %}<input type="hidden" name="series" value="{{ filterQuery.series }}">{% endif %}
            {% if filterQuery.era is defined %}<input type="hidden" name="era" value="{{ filterQuery.era }}">{% endif %}
            {% if filterQuery.tag is defined %}<input type="hidden" name="tag" value="{{ filterQuery.tag }}">{% endif %}
            <input type="hidden" name="featured" value="1" data-featured-input{% if not activeFeatured %} disabled{% endif %}>

            <div class="chronicle-hub__toolbar">
                <label class="chronicle-hub__year">
                    <span class="visually-hidden">Год</span>
                    <select name="year" data-chronicle-auto>
                        <option value="">Все годы</option>
                        {% for y in years %}
                            <option value="{{ y }}"{% if activeYear == y %} selected{% endif %}>{{ y }}</option>
                        {% endfor %}
                    </select>
                </label>
                <button
                    type="button"
                    class="chronicle-hub__heart-btn{% if activeFeatured %} is-active{% endif %}"
                    data-chronicle-heart
                    aria-pressed="{{ activeFeatured ? 'true' : 'false' }}"
                    title="{{ activeFeatured ? 'Показать все' : 'Только избранное' }}"
                >
                    <svg class="chronicle-hub__heart-icon" width="36" height="36" viewBox="0 0 36 36" aria-hidden="true" focusable="false">
                        <circle class="chronicle-hub__heart-chrome" cx="18" cy="18" r="16.5"/>
                        <g transform="translate(18 18.4) scale(0.76)">
                            <path
                                class="chronicle-hub__heart-shape"
                                transform="translate(-12 -10.8)"
                                d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"
                            />
                        </g>
                    </svg>
                    <span class="visually-hidden">Избранное</span>
                </button>
                <button
                    type="button"
                    class="chronicle-hub__filters-toggle{% if filterCount > 0 %} is-active{% endif %}"
                    data-chronicle-filters-toggle
                    aria-expanded="false"
                    aria-controls="chronicle-filters-panel"
                >
                    Фильтры{% if filterCount > 0 %}<span class="chronicle-hub__filters-count">{{ filterCount }}</span>{% endif %}
                </button>
                {% if filterCount > 0 %}
                    <a class="chronicle-hub__reset" href="{{ path('web_chronicle') }}" data-chronicle-filters-reset>Сбросить</a>
                {% endif %}
            </div>

            <div
                class="chronicle-hub__panels{% if filterCount > 0 %} is-open{% endif %}"
                id="chronicle-filters-panel"
                data-chronicle-filters-panel
            >
                {% if seriesList is not empty %}
                    <div class="chronicle-hub__row" role="navigation" aria-label="Каналы">
                        <p class="chronicle-hub__row-label">Каналы</p>
                        <div class="chronicle-hub__scroller">
                            <a class="chronicle-chip{% if not activeSeries %} is-active{% endif %}" href="{{ path('web_chronicle', filterQuery|filter((v, k) => k != 'series')) }}">Все</a>
                            {% for s in seriesList %}
                                <a
                                    class="chronicle-chip{% if activeSeries and activeSeries.id == s.id %} is-active{% endif %}"
                                    href="{{ path('web_chronicle', filterQuery|merge({series: s.slug})) }}"
                                >{{ s.title }}</a>
                            {% endfor %}
                        </div>
                    </div>
                {% endif %}

                <div class="chronicle-hub__row" role="navigation" aria-label="Эпохи">
                    <p class="chronicle-hub__row-label">Эпохи</p>
                    <div class="chronicle-hub__scroller">
                        <a class="chronicle-chip{% if not activeEra %} is-active{% endif %}" href="{{ path('web_chronicle', filterQuery|filter((v, k) => k != 'era')) }}">Все</a>
                        {% for era in eras %}
                            <a
                                class="chronicle-chip{% if activeEra and activeEra.id == era.id %} is-active{% endif %}"
                                href="{{ path('web_chronicle', filterQuery|merge({era: era.slug})) }}"
                                {% if era.color %}style="--chip-accent: {{ era.color }}"{% endif %}
                            >{{ era.title }}</a>
                        {% endfor %}
                    </div>
                </div>

                {% if tags is not empty %}
                    <div class="chronicle-hub__row" role="navigation" aria-label="Теги">
                        <p class="chronicle-hub__row-label">Теги</p>
                        <div class="chronicle-hub__scroller chronicle-hub__scroller--wrap">
                            <a
                                class="chronicle-tag{% if not activeTag %} is-active{% endif %}"
                                href="{{ path('web_chronicle', filterQuery|filter((v, k) => k != 'tag')) }}"
                            >Все</a>
                            {% for tag in tags %}
                                <a
                                    class="chronicle-tag{% if activeTag and activeTag.id == tag.id %} is-active{% endif %}"
                                    href="{{ path('web_chronicle', filterQuery|merge({tag: tag.slug})) }}"
                                >#{{ tag.name }}</a>
                            {% endfor %}
                        </div>
                    </div>
                {% endif %}
            </div>
        </form>

        <div
            class="chronicle-feed"
            data-chronicle-feed
            data-more-url="{{ path('web_chronicle_more') }}"
            data-next-offset="{{ nextOffset }}"
            data-has-more="{{ hasMore ? '1' : '0' }}"
            data-query="{{ filterQuery|json_encode|e('html_attr') }}"
        >
            {% include 'web/chronicle/_entries.html.twig' with {entries: entries, hubQuery: filterQuery} %}
        </div>

        {% if hasMore %}
            <div class="chronicle-hub__more">
                <button type="button" class="btn btn--ghost" data-chronicle-more>
                    Смотреть ещё
                </button>
            </div>
        {% endif %}
    </div>
</section>

{% include 'web/_partials/page_nav.html.twig' with {
    backFallback: path('web_home'),
    related: [
        { href: path('web_cases'), label: 'Кейсы' },
        { href: path('web_contact'), label: 'Связь' },
    ]
} %}
{% endblock %}
