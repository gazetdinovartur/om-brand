{% set cover = chronicle_cover(entry.coverImagePath) %}
{% set href = path('web_chronicle_show', {slug: entry.slug}) %}
{% set hubQuery = hubQuery|default({}) %}

<article class="chronicle-entry{% if featured|default(false) %} chronicle-entry--featured{% endif %}" id="chronicle-{{ entry.slug }}">
    <a class="chronicle-entry__media{% if not cover %} chronicle-entry__media--default{% endif %}" href="{{ href }}"{% if not cover %} aria-hidden="true" tabindex="-1"{% endif %}>
        {% if cover %}
            <img
                class="chronicle-entry__cover"
                src="{{ asset(cover) }}"
                alt="{{ entry.title }}"
                loading="lazy"
                decoding="async"
            >
        {% else %}
            <span
                class="chronicle-entry__cover chronicle-entry__cover--default"
                {% if entry.era and entry.era.color %}style="--era-color: {{ entry.era.color }}"{% endif %}
            >
                {% include 'web/chronicle/_default_cover_mark.html.twig' %}
            </span>
        {% endif %}
    </a>
    <div class="chronicle-entry__body">
        <div class="chronicle-entry__meta">
            {% if featured|default(false) %}
                <span class="chronicle-entry__heart" title="Избранное" aria-label="Избранное">♥</span>
            {% endif %}
            {% if entry.series %}
                <a class="chronicle-series-chip" href="{{ path('web_chronicle', hubQuery|merge({series: entry.series.slug})) }}">{{ entry.series.title }}</a>
            {% endif %}
            {% if entry.era %}
                <a class="chronicle-era-chip" href="{{ path('web_chronicle', hubQuery|merge({era: entry.era.slug})) }}"{% if entry.era.color %} style="--era-color: {{ entry.era.color }}"{% endif %}>{{ entry.era.title }}</a>
            {% endif %}
            {% if entry.publishedAt %}
                <time datetime="{{ entry.publishedAt|date('c') }}">{{ entry.publishedAt|chronicle_date('short') }}</time>
            {% endif %}
        </div>
        <h2 class="chronicle-entry__title"><a href="{{ href }}">{{ entry.title }}</a></h2>
        {% if chronicle_show_card_lede(entry) %}
            <p class="chronicle-entry__lede">{% if entry.lede|length > 140 %}{{ entry.lede|slice(0, 140)|trim }}…{% else %}{{ entry.lede }}{% endif %}</p>
        {% endif %}
        {% if entry.tags is not empty %}
            <div class="chronicle-entry__tags">
                {% for tag in entry.tags %}
                    <a class="chronicle-tag" href="{{ path('web_chronicle', hubQuery|merge({tag: tag.slug})) }}">#{{ tag.name }}</a>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</article>
