{% set cover = upload_path(entry.coverImagePath, 'chronicle/covers') %}
{% set href = path('web_chronicle_show', {slug: entry.slug}) %}

<article class="chronicle-entry{% if featured|default(false) %} chronicle-entry--featured{% endif %}">
    {% if cover %}
        <a class="chronicle-entry__media" href="{{ href }}">
            <img
                class="chronicle-entry__cover"
                src="{{ asset(cover) }}"
                alt="{{ entry.title }}"
                loading="lazy"
                decoding="async"
            >
        </a>
    {% endif %}
    <div class="chronicle-entry__body">
        <div class="chronicle-entry__meta">
            {% if entry.era %}
                <a class="chronicle-entry__era" href="{{ path('web_chronicle_era', {slug: entry.era.slug}) }}"{% if entry.era.color %} style="--era-color: {{ entry.era.color }}"{% endif %}>{{ entry.era.title }}</a>
            {% endif %}
            {% if entry.publishedAt %}
                <time datetime="{{ entry.publishedAt|date('c') }}">{{ entry.publishedAt|date('j M Y') }}</time>
            {% endif %}
            <span>{{ entry.readingTimeMin }} мин</span>
        </div>
        <h2 class="chronicle-entry__title"><a href="{{ href }}">{{ entry.title }}</a></h2>
        {% if entry.lede %}
            <p class="chronicle-entry__lede">{{ entry.lede }}</p>
        {% endif %}
        {% if entry.tags is not empty %}
            <div class="chronicle-entry__tags">
                {% for tag in entry.tags %}
                    <a class="chronicle-tag" href="{{ path('web_chronicle_tag', {slug: tag.slug}) }}">#{{ tag.name }}</a>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</article>
