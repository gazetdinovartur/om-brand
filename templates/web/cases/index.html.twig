{% extends 'web/layout.html.twig' %}

{% block body %}
<section class="section cases-hub">
    <div class="container">
        <header class="cases-hub__head">
            <p class="cases-hub__eyebrow">Практика</p>
            <h1 class="section__title cases-hub__title">Кейсы</h1>
            <p class="section__subtitle cases-hub__lead">Что заинтересовало, как собрал, какую задачу решило.</p>
        </header>

        {% if cases is empty %}
            <p class="cases-hub__empty">Скоро здесь появятся первые истории.</p>
        {% else %}
            <div class="cases-hub__list" data-lightbox-gallery>
                {% for case in cases %}
                    {% include 'web/_partials/case_entry.html.twig' with {
                        case: case,
                        zoomable: true,
                        withId: true,
                        linkLabel: 'Читать кейс'
                    } %}
                {% endfor %}
            </div>
        {% endif %}
    </div>
</section>

{% include 'web/_partials/page_nav.html.twig' with {
    backFallback: path('web_home'),
    related: [
        { href: path('web_dev_landing'), label: 'Разработка' },
        { href: path('web_chronicle'), label: 'Хроника' },
        { href: path('web_contact'), label: 'Связь' },
    ]
} %}
{% endblock %}
