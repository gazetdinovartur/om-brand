###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=change_me_generate_random_32_chars
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
DATABASE_URL="mysql://site:change_me_db_password@mysql:3306/site?serverVersion=8.0&charset=utf8mb4"
###< doctrine/doctrine-bundle ###

###> symfony/mailer ###
# null://null — письма не отправляются (dev). Пример: smtp://user:pass@smtp.example.com:587
MAILER_DSN=null://null
# Отправитель (должен совпадать с логином SMTP). Пример: info@arturlun.ru
MAILER_FROM=
###< symfony/mailer ###

# Публичный URL сайта для canonical и Open Graph (prod обязательно)
# Prod: https://arturlun.ru
APP_SITE_URL=http://localhost:8085

# Версия статики (css/js). Меняйте при каждом релизе фронта, чтобы сбросить кэш браузеров.
ASSETS_VERSION=20260723a

# Админ (используется app:seed)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_strong_password

# Telegram-уведомления о заявках (опционально)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Шаблон ссылки СБП (опционально; приоритет у поля в админке → Настройки)
# Плейсхолдеры: {amount_rubles}, {amount}, {token}, {title}, {id}
SBP_PAYMENT_URL_TEMPLATE=

# OmPlayer embed (кейсы с голосом)
OM_PLAYER_SCRIPT_URL=https://music.arturlun.ru/build/player/om-player.iife.js
OM_PLAYER_API_BASE=https://music.arturlun.ru/api/v1

# Тяжёлые экспорты вне репо (Instagram / Google Photos) — пути на машине
# CONTENT_INSTAGRAM_PATH=/Users/you/Downloads/instagram-….zip
# CONTENT_GOOGLE_PHOTOS_PATH=/Users/you/Downloads/takeout-….zip
CONTENT_INSTAGRAM_PATH=
CONTENT_GOOGLE_PHOTOS_PATH=

# Docker / локальная разработка
DEFAULT_URI=http://localhost:8085
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=site
MYSQL_USER=site
MYSQL_PASSWORD=change_me_db_password

# Деплой / sync с машины разработчика (не на сервере)
# DEPLOY_SSH=c502022@91.201.52.29
# DEPLOY_REMOTE_ROOT=/home/c502022/arturlun.ru/om-brand
# DEPLOY_SSH_PORT=22
# DEPLOY_SSH_IDENTITY=~/.ssh/arturlun_deploy
